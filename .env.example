# Clean24 Lead Autopilot webhook integration
# Set these in .env.local (never commit .env.local)

# URL of the Clean24 Lead Autopilot webhook endpoint
CLEAN24_LEAD_WEBHOOK_URL=

# Secret header value sent as x-webhook-secret
CLEAN24_LEAD_WEBHOOK_SECRET=

# Discount/Rabattcode validation endpoint on the Lead Autopilot, e.g.
# https://<autopilot-host>/api/discount-codes/validate
# Auth reuses CLEAN24_LEAD_WEBHOOK_SECRET (sent as x-webhook-secret, server-only).
# Leave empty to disable discount codes (no-code flow stays unchanged).
CLEAN24_DISCOUNT_VALIDATE_URL=

# Public (browser-facing) upload endpoint on the Lead Autopilot for optional
# customer photos/PDFs, e.g. https://<autopilot-host>/api/uploads/website-lead
# This is a public URL, NOT a secret. Leave empty to disable the photo upload
# (the lead form keeps working without photos).
NEXT_PUBLIC_CLEAN24_LEAD_UPLOAD_URL=

# ---- Email / SMTP (Cyon mailbox) ----
# Used to send the internal lead notification and the customer checklist email.
# Set the real values in .env.local (never commit) and in the Vercel project.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
# Full From header, e.g. Clean24 Memis GmbH <info@clean-24.ch>
EMAIL_FROM=
# Internal inbox that receives lead + checklist notifications
ADMIN_NOTIFICATION_EMAIL=

# ---- Tracking (v0.2) ----
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GADS_CONVERSION_ID=AW-XXXXXXXXXX
# NEXT_PUBLIC_FB_PIXEL_ID=XXXXXXXXXXXXXXXXXX
